<?xml version="1.0" encoding="us-ascii"?>
<marlin xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://ilcsoft.desy.de/marlin/marlin.xsd">

    <constants>
    </constants>

    <!-- ======================================================================================================== -->
    <!-- ======================================================================================================== -->
    <!-- == List of processors to execute                                                                      == -->
    <!-- ======================================================================================================== -->
    <!-- ======================================================================================================== -->

    <execute>
        <processor name="MyAIDAProcessor"/>
        <processor name="EventNumber" />

        <!--==========TauSpecific======== -->
        <processor name="MyTauFinder"/>
        <processor name="MyRecoMCTruthLinker"/>

        <processor name="LCIOWriter"/>
    </execute>

    <global>
        <parameter name="LCIOInputFiles">input.slcio</parameter>
        <!-- Limit the number of processed records -->
        <parameter name="MaxRecordNumber" value="-1" />
        <parameter name="SkipNEvents" value="0" />
        <parameter name="SupressCheck" value="false" />
        <parameter name="Verbosity" options="DEBUG0-9,MESSAGE0-9,WARNING0-9,ERROR0-9,SILENT">DEBUG </parameter>
        <parameter name="RandomSeed" value="1234567890" />
    </global>

    <include ref="../../RecoMCTruthLink/share/MyRecoMCTruthLinker.xml"/>

    <!--==========TAUS============-->
    <processor name="MyTauFinder" type="TauFinder">
        <!--TauFinder writes tau candidates as ReconstructedParticles into collection. It runs on a collection of ReconstructedParticels, if you want  to run on MCParticles you have to convert them before hand (use e.g. PrepareRECParticles processor)-->
        <!--Collection of PFOs-->
        <parameter name="PFOCollection" type="string" lcioInType="ReconstructedParticle">PandoraPFOs_JETS </parameter>
        <!--Collection of Tau Candidates-->
        <parameter name="RecoTauCollection" type="string" lcioOutType="ReconstructedParticle">RecoTaus </parameter>
        <!--Name of the Tau link to ReconstructedParticle collection-->
	<parameter name="RecoTauChargedTrackCollection" type="string" lcioOutType="ReconstructedParticle">RecoTausNChargedTrks </parameter>
        <!--Name of the Tau link to ReconstructedParticle collection-->
        <parameter name="RecoTauInvMassCollection" type="string" lcioOutType="ReconstructedParticle">RecoTausInvMass </parameter>
	<!--Name of the Tau link to ReconstructedParticle collection-->
        <parameter name="RecoTauMergeCollection" type="string" lcioOutType="ReconstructedParticle">RecoTausMerge </parameter>
	<!--Name of the Tau link to ReconstructedParticle collection-->
        <parameter name="RecoTauNParticlesCollection" type="string" lcioOutType="ReconstructedParticle">RecoTausNParticles </parameter>
	<!--Name of the Tau link to ReconstructedParticle collection-->
        <parameter name="RecoTauIsoEnergyCollection" type="string" lcioOutType="ReconstructedParticle">RecoTausIsoEnergy </parameter>
        <!--Name of the Tau link to ReconstructedParticle collection-->
	<parameter name="TauPFOLinkCollectionName" type="string" lcioOutType="LCRelation">TauPFOLink </parameter>
        <!--verbosity level of this processor ("DEBUG0-4,MESSAGE0-4,WARNING0-4,ERROR0-4,SILENT")-->
        <parameter name="Verbosity" type="string">DEBUG4</parameter>
	<!--Name of output file-->
	<parameter name="fileName" type="string">taufinder_cone_15_pt_100.root</parameter>
        <!--Outer isolation cone around search cone of tau jet in rad (relativ to cone angle)-->
        <parameter name="isolationConeAngle" type="float">0.2 </parameter>
        <!--Energy allowed within isolation cone region-->
        <parameter name="isolationEnergy" type="float">100000</parameter>
        <!--Cut on pt to suppress background-->
        <parameter name="ptCut" type="float">1.0</parameter>
        <!--Minimum tranverse momentum of tau seed-->
        <parameter name="ptSeed" type="float">1.0</parameter>
        <!--Opening angle of the search cone for tau jet in rad-->
        <parameter name="searchConeAngle" type="float">0.15</parameter>
	<!--Cut on inv mass of reconstructed tau-->
        <parameter name="invMass" type="float">100000</parameter>
    </processor>

    <processor name="MyAIDAProcessor" type="AIDAProcessor">
        <!--Processor that handles AIDA files. Creates on directory per processor.  Processors only need to create and fill the histograms, clouds and tuples. Needs to be the first ActiveProcessor-->
        <!-- compression of output file 0: false >0: true (default) -->
        <parameter name="Compress" type="int" value="1"/>
        <!-- filename without extension-->
        <parameter name="FileName" type="string" value="output_taufinder_cone_15_pt_100"/>
        <!-- type of output file xml (default) or root ( only OpenScientist)-->
        <parameter name="FileType" type="string" value="root "/>
    </processor>

    <processor name="EventNumber" type="Statusmonitor">
        <parameter name="HowOften" type="int">10 </parameter>
        <parameter name="Verbosity" type="string"> MESSAGE </parameter>
    </processor>

    <!-- LCIO output: keep all collections -->
    <processor name="LCIOWriter" type="LCIOOutputProcessor">
        <parameter name="LCIOOutputFile" type="string"> output_taufinder_cone_15_pt_100.slcio </parameter>
        <parameter name="FullSubsetCollections" type="StringVec"></parameter>
        <parameter name="DropCollectionTypes" type="StringVec">
        CalorimeterHit
        SimCalorimeterHit
        Track
        SimTrackerHit
        ReconstructedParticle
        LCRelation
        Cluster
        Vertex
        TrackerHitPlane
        </parameter>
        <parameter name="DropCollectionNames" type="StringVec"></parameter>
        <parameter name="KeepCollectionNames" type="StringVec">
        MCParticle
        RecoMCTruthLink
        TauPFOLink
        RecoTaus
	RecoTausInvMass
	RecoTausNChargedTrks
	RecoTausMerge
	RecoTausNParticles
	RecoTausIsoEnergy
        SiTracks_Refitted_JETS
        PandoraPFOs_JETS
        </parameter>
        <parameter name="LCIOWriteMode" type="string" value="WRITE_NEW"/>
        <parameter name="Verbosity" type="string">MESSAGE </parameter>
        <!-- <parameter name="SplitFileSizekB" type="int">996147 </parameter> -->
    </processor>
</marlin>
